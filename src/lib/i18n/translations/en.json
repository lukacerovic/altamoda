  "education": {
    "heroTag": "ID HAIR ACADEMY",
    "heroTitle": "Education Center",
    "heroSubtitle": "The place where successful hairdressers are made",
    "introText": "ID HAIR ACADEMY hair salon is located in the very center of Belgrade, at Kneza Miloša 23. When it comes to hairstyling services, clients receive expert advice — they can consult with top hairstylists about which shapes and colors best suit their face shape, skin tone, style of dressing, lifestyle, and choose their ideal hairstyle.",
    "educationTitle": "Education as the key to success",
    "educationText": "Based on many years of experience in the hairdressing craft, the ID Hair Academy team has established that the key to success is primarily adequate EDUCATION. Following trends, improving the concept and strategy of education, and finding the perfect balance between theory and practice, have led to a five-month educational program (from September to February).",
    "approachTitle": "A thorough approach to work",
    "approachText": "With a thorough approach to work and maximum dedication from educators, step by step and very precisely, it is possible to go from complete ignorance to leaving the academy as a hairdresser capable of independent work. This is exactly what distinguishes this academy from other hairdressing schools.",
    "founderTitle": "Founder & Art Director",
    "founderText": "Founder and art director and top master among hairdressers in this region, Zoran Janković often emphasizes how selflessly, since 2001, together with his team, he has been bringing innovations and technically providing opportunities for knowledge advancement both in the five-month training and during shorter individual courses. Another advantage of ID Hair Academy is working on live models for both cutting and coloring.",
    "successTitle": "Creating successful hairdressers",
    "successText": "Students who graduated from ID Hair Academy are now hairdressers, stylists, educators, and salon owners around the world, so it can rightfully be said that this is the place where successful hairdressers are made.",
    "contactTitle": "More information",
    "contactText": "For more information about courses and education:",
    "welcomeText": "WELCOME!",
    "modelCallTitle": "Want to be a model?",
    "modelCallText": "Want to be a model for the most successful hair academy? Send photos of your hair, face, and full figure to info@id-academy.com",
    "seeYou": "SEE YOU!",
    "programDuration": "5 months",
    "programDurationLabel": "Program duration",
    "since": "Since 2001",
    "sinceLabel": "Years of experience",
    "liveModels": "Live models",
