  "about": {
    "heroTag": "Established 1996",
    "heroTitle1": "The Art of",
    "heroTitle2": "Distribution",
    "heroDescription": "For nearly three decades, Altamoda has stood as a silent architect behind Serbia's luxury hair care landscape. A family legacy built on the foundations of trust, expertise, and an unwavering commitment to professional excellence.",
    "heroQuote": "\"Quality is not an act, it is a habit.\"",
    "heroQuoteAttribution": "— The Founding Philosophy",
    "familyJourneyTitle1": "A Family",
    "familyJourneyTitle2": "Journey",
    "familyJourneyDescription": "What started as a passionate vision in 1996 has evolved into Serbia's premier gateway for global luxury beauty brands.",
    "genesisTitle": "1996: The Genesis",
    "genesisDescription": "Founded in Belgrade, Altamoda began with a simple mission: to provide Serbian stylists with the same high-caliber tools and products available in the fashion capitals of Paris and Milan.",
    "reliabilityTitle": "The Reliability Factor",
    "reliabilityQuote": "\"In distribution, reliability is the only currency that matters. We don't just move products; we nurture the growth of our partners, ensuring that every salon we serve has the support to become a landmark of style.\"",
